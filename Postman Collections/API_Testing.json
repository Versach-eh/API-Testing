	"item": [
		{
			"name": "Get Users",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"})",
							"",
							"pm.test('Response is JSON', function () {",
							"    pm.response.to.have.header('Content-Type');",
							"    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
							"})",
							"",
							"pm.test('Response is a non-empty array of users with required fields', function () {",
							"    const json = pm.response.json();",
							"    pm.expect(json).to.be.an('array');",
							"    pm.expect(json.length).to.be.above(0);",
							"    json.forEach(u => {",
							"        pm.expect(u).to.be.an('object');",
							"        pm.expect(u).to.have.property('id');",
							"        pm.expect(u).to.have.property('name');",
							"        pm.expect(u).to.have.property('username');",
							"        pm.expect(u).to.have.property('email');",
							"    });",
							"})"
						]
					}
				}
			],
